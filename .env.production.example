# ===========================================
# KANBEX — PRODUCTION ENVIRONMENT
# ===========================================
# Copy to /home/murx/apps/tasktrox/.env.production on VPS
# NEVER commit this file with real values.
#
# For shared infra env vars (postgres password), see .env.infra.example

NODE_ENV=production
PORT=4000


# Redis (shared instance)
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=<MIN_64_CHAR_RANDOM_STRING>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — subdomain, not root domain
CORS_ORIGIN=https://tasktrox.thecodeman.cloud
FRONTEND_URL=https://tasktrox.thecodeman.cloud

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OAuth — callback URLs use subdomain
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tasktrox.thecodeman.cloud/api/v1/auth/google/callback


# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@thecodeman.cloud

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tasktrox-files
R2_PUBLIC_URL=
